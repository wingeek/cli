{
  "name": "@wingeek/artisan",
  "version": "0.1.0",
  "description": "A CLI for builders — 结构化工作日志 + 多平台内容发布，本地优先",
  "keywords": ["cli", "publish", "worklog", "content", "markdown", "juejin", "wechat", "twitter"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wingeek/artisan.git"
  },
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "artisan": "src/index.tsx"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun run scripts/build.ts",
    "build:bin": "bun run scripts/build.ts -- --compile",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@cliffy/command": "npm:@jsr/cliffy__command",
    "@jsr/cliffy__command": "^1.1.1",
    "@opentui/core": "^0.3.0",
    "@opentui/solid": "^0.3.0",
    "babel-preset-solid": "1.9.12",
    "solid-js": "1.9.12"
  }
}